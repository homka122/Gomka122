{
    "swagger": "2.0",
    "info": {
        "title": "Gomka122 API",
        "contact": {
            "name": "Homka122",
            "url": "t.me/homka122",
            "email": "kombaev02@gmail.com"
        },
        "license": {
            "name": "MIT",
            "url": "https://mit-license.org/"
        },
        "version": "0.1"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/ping": {
            "get": {
                "description": "get status of services",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "service"
                ],
                "summary": "Get status of services",
                "operationId": "get-status-of-services",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.ServicesInfo"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/controller.GetRepository.HTTPError"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/domain.ServicesInfo"
                        }
                    }
                }
            }
        },
        "/api/repositories/info": {
            "get": {
                "description": "get repository information by GitHub repository URL",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "repo"
                ],
                "summary": "Get repository by GitHub URL",
                "operationId": "get-repo-by-owner-repo",
                "parameters": [
                    {
                        "type": "string",
                        "description": "GitHub repository URL",
                        "name": "url",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.Repository"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/controller.GetRepository.HTTPError"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/controller.GetRepository.HTTPError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/controller.GetRepository.HTTPError"
                        }
                    },
                    "502": {
                        "description": "Bad Gateway",
                        "schema": {
                            "$ref": "#/definitions/controller.GetRepository.HTTPError"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "controller.GetRepository.HTTPError": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "some error"
                }
            }
        },
        "domain.PingStatus": {
            "type": "string",
            "enum": [
                "up",
                "down"
            ],
            "x-enum-varnames": [
                "PingStatusUp",
                "PingStatusDown"
            ]
        },
        "domain.Repository": {
            "type": "object",
            "properties": {
                "create_date": {
                    "type": "string",
                    "example": "2026-03-03T16:45:04Z"
                },
                "description": {
                    "type": "string",
                    "example": "homka's repo"
                },
                "forks": {
                    "type": "integer",
                    "example": 2
                },
                "name": {
                    "type": "string",
                    "example": "homka122"
                },
                "stars": {
                    "type": "integer",
                    "example": 122
                }
            }
        },
        "domain.ServiceStatus": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "status": {
                    "$ref": "#/definitions/domain.PingStatus"
                }
            }
        },
        "domain.ServicesInfo": {
            "type": "object",
            "properties": {
                "services": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/domain.ServiceStatus"
                    }
                },
                "status": {
                    "$ref": "#/definitions/domain.ServicesStatus"
                }
            }
        },
        "domain.ServicesStatus": {
            "type": "string",
            "enum": [
                "ok",
                "degraded"
            ],
            "x-enum-varnames": [
                "ServicesStatusOk",
                "ServicesStatusDegraded"
            ]
        }
    }
}